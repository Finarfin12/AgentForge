# AgentForge Heartbeat Client Configuration
# Copy this file to .env and fill in your values

# Backend WebSocket URL (for real-time heartbeats - recommended)
BACKEND_WS_URL=http://localhost:3001

# Backend REST URL (for auto-registration and REST fallback)
BACKEND_API_URL=http://localhost:3001

# JWT Token (OPTIONAL - not required for registration or heartbeat)
# The /agents/register and /agents/:id/heartbeat endpoints are public.
# Only set this if you need to access protected endpoints (list agents, etc.)
AGENT_TOKEN=

# Agent Configuration (used for auto-registration)
AGENT_NAME=local_my_agent
AGENT_DISPLAY_NAME=My Local Agent
AGENT_DESCRIPTION=Auto-registered local AI agent
AGENT_PROVIDER=ollama
AGENT_MODEL=default
AGENT_PORT=11434

# Heartbeat Settings
HEARTBEAT_INTERVAL_MS=30000
RECONNECT_DELAY_MS=5000
MAX_RECONNECT_ATTEMPTS=0
