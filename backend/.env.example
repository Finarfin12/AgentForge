# === Core ===
PORT=3002
JWT_SECRET=your-secret-key-change-this-in-production

# === Database ===
# Adjust to your PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5433/agentforge

# === Redis ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# === AI Providers ===
# Ollama (auto-detected if running)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible (any provider)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here

# === SMTP (Email) ===
# Configure to enable password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@agentforge.local

# === Auto-Discovery ===
AUTO_DISCOVER_ON_STARTUP=true
SCAN_PORTS=11434,8080,8000,5000,7860,1234
