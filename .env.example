# === Core ===
PORT=3002
JWT_SECRET=change-this-in-production

# === Database (PostgreSQL via Docker) ===
# Docker maps host port 5433 → container 5432
DATABASE_URL=postgresql://postgres:password@localhost:5433/agentforge

# === Redis (via Docker) ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# === AI Providers ===
# Ollama (auto-detected if running locally)
OLLAMA_BASE_URL=http://localhost:11434
# OpenAI-compatible API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# === Marketplace ===
# GitHub token increases API rate limit for skill search
GITHUB_TOKEN=

# === Discovery ===
AUTO_DISCOVER_ON_STARTUP=true
SCAN_PORTS=11434,8080,8000,5000,7860,1234
